{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [ "${mod_authors_list}" ],
  "contact": {
    "homepage": "https://github.com/mahmudindev",
    "sources": "https://github.com/mahmudindev/mcmod-desertdimension"
  },
  "license": "${mod_license}",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.github.mahmudindev.mcmod.desertdimension.fabric.DesertDimensionFabric"
    ],
    "client": [
      "com.github.mahmudindev.mcmod.desertdimension.fabric.client.DesertDimensionFabricClient"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "java": ">=${java_version}",
    "dimensionfixer": ">=${dimensionfixer_version}",
    "worldportal": ">=${worldportal_version}"
  },
  "suggests": {
    "fabric-api": "*"
  }
}
